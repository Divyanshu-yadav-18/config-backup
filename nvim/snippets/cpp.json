  "CP OO Template": {
    "prefix": "cp",
    "body": [
      "#include <bits/stdc++.h>",
      "",
      "using namespace std;",
      "",
      "// --- Unique Type Definitions ---",
      "using i64 = long long;",
      "using vi = vector<int>;",
      "using v64 = vector<i64>;",
      "",
      "// --- Custom I/O Helper ---",
      "template<typename T> void read(T& x) { cin >> x; }",
      "template<typename T, typename... Args> void read(T& x, Args&... args) { cin >> x; read(args...); }",
      "",
      "// --- The Solution Wrapper ---",
      "class Solver {",
      "public:",
      "    void run() {",
      "        $1",
      "    }",
      "};",
      "",
      "// --- Main Execution ---",
      "int main() {",
      "    ios_base::sync_with_stdio(false);",
      "    cin.tie(nullptr);",
      "",
      "    int t = 1;",
      "    cin >> t;",
      "",
      "    while(t--) {",
      "        Solver solver;",
      "        solver.run();",
      "    }",
      "",
      "    return 0;",
      "}"
    ],
    "description": "Object Oriented Competitive Programming Template"
  }
